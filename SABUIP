		currentLoadingConnection = nil
	end
end

-- ========== FUNCTION PARA MAG-RESTART ==========
local function restartProcess()
	print("🔄 RESTARTING PROCESS...")
	
	-- I-stop ang kasalukuyang loading kung mayroon
	stopCurrentLoading()
	
	-- Itago ang error frame
	ErrorFrame.Visible = false
	
	-- I-reset ang toggle states
	toggleStates.freezeTrade = false
	toggleStates.autoReady = false
	toggleStates.autoAccept = false
	
	-- I-reset ang toggle switches
