-- ========== INITIAL LOADING ANIMATION (2 MINUTES with EASING) ==========
local function runInitialLoading()
	-- Fade in loading frame
	local fadeInInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	local fadeInLoading = tweenService:Create(LoadingFrame, fadeInInfo, {BackgroundTransparency = 0})
	fadeInLoading:Play()

	wait(0.1)

	-- Fade in loading text
	local fadeInText = tweenService:Create(LoadingText, fadeInInfo, {TextTransparency = 0})
	fadeInText:Play()

	-- Fade in bar background
	local fadeInBarBg = tweenService:Create(barBg, fadeInInfo, {BackgroundTransparency = 0})
	fadeInBarBg:Play()

	wait(0.3)

	-- REAL LOADING BAR ANIMATION (2 MINUTES = 120 seconds)
	local startTime = tick()
	local loadingDuration = 120 -- 2 minutes in seconds

	-- Initialize loading bar
	LoadingBar.Size = UDim2.new(0, 0, 1, 0)
	LoadingBar.BackgroundColor3 = Color3.fromRGB(76, 175, 80)  -- Bright Green
	LoadingBar.Visible = true

	-- List of loading messages para sa 2 minutes
	local loadingMessages = {
		"Initializing DarkZ Script...",
		"Loading modules...",
		"Connecting to server...",
		"Please wait...",
		"Almost there...",
		"Just a moment...",
		"Finalizing setup...",
		"DARKZ SCRIPT"
	}

	local messageIndex = 1
	local lastMessageChange = tick()
	local messageInterval = 15 -- Change message every 15 seconds

	-- Continuous update loop para sa smooth na loading bar
	local connection
	connection = game:GetService("RunService").Heartbeat:Connect(function()
		local elapsed = tick() - startTime
		-- Gumamit ng exponential easing para mabilis sa simula, pabagal ng pabagal
		-- progress = 1 - (1 - t)^3  (cubic easing - mabilis sa simula, bagal sa dulo)
		local t = math.min(elapsed / loadingDuration, 1)
		local progress = 1 - (1 - t)^3  -- Cubic easing: mabilis sa simula, bagal sa dulo

		-- Update loading bar size with easing
		LoadingBar.Size = UDim2.new(progress, 0, 1, 0)

		-- Change loading message every 15 seconds
		if tick() - lastMessageChange >= messageInterval then
			messageIndex = (messageIndex % #loadingMessages) + 1
			LoadingText.Text = loadingMessages[messageIndex]
			lastMessageChange = tick()
		end

		-- Update text based on progress (minsan may special messages)
		if progress < 0.1 then
			LoadingText.Text = "Loading DarkZ Script..."
		elseif progress > 0.95 then
			LoadingText.Text = "Almost Complete!"
		end

		-- Stop when done
		if progress >= 1 then
			connection:Disconnect()

			LoadingText.Text = "Complete!"

			-- Small delay para makita ang "Complete!" text
			wait(1)

			-- Fade out loading frame
			local fadeOutInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

			local fadeOutLoading = tweenService:Create(LoadingFrame, fadeOutInfo, {BackgroundTransparency = 1})
			fadeOutLoading:Play()

			local fadeOutText = tweenService:Create(LoadingText, fadeOutInfo, {TextTransparency = 1})
			fadeOutText:Play()

			local fadeOutBarBg = tweenService:Create(barBg, fadeOutInfo, {BackgroundTransparency = 1})
			fadeOutBarBg:Play()

			wait(0.2)

			-- Show main frame
			Frame.Visible = true

			-- Remove loading frame
			wait(0.3)
			LoadingFrame:Destroy()
		end
	end)
end

-- ========== TOGGLE ACTIVATION FUNCTION (WITH CUSTOM LOADING TIMES and GREEN bar) ==========
local isLoadingActive = false

local function showToggleLoading(toggleName, callback, loadingTime)
	if isLoadingActive then
		return
	end

	isLoadingActive = true

	ToggleLoadingFrame.Position = UDim2.new(0.5, -150, 0.5, -75)
	ToggleLoadingFrame.Visible = true
	ToggleLoadingFrame.BackgroundTransparency = 1
	ToggleLoadingBar.Size = UDim2.new(0, 0, 1, 0)
	ToggleLoadingBar.BackgroundColor3 = Color3.fromRGB(76, 175, 80)  -- Bright Green
	ToggleLoadingBar.Visible = true
	ToggleLoadingText.Text = "Activating " .. toggleName .. "..."
	ToggleLoadingText.TextTransparency = 1

	local fadeInInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	tweenService:Create(ToggleLoadingFrame, fadeInInfo, {BackgroundTransparency = 0}):Play()
	tweenService:Create(ToggleLoadingText, fadeInInfo, {TextTransparency = 0}):Play()
	tweenService:Create(toggleBarBg, fadeInInfo, {BackgroundTransparency = 0}):Play()

	wait(0.2)

	-- REAL LOADING BAR for toggle activation (GREEN) - with linear progress (walang easing)
	local startTime = tick()

	-- Continuous update loop para sa smooth na loading bar
	local connection
	connection = game:GetService("RunService").Heartbeat:Connect(function()
		local elapsed = tick() - startTime
		local progress = math.min(elapsed / loadingTime, 1)

		-- Update loading bar size based on actual elapsed time (linear)
		ToggleLoadingBar.Size = UDim2.new(progress, 0, 1, 0)

		-- Update text based on progress
		if loadingTime == 4 then
			-- For Freeze Trade (4 seconds)
			if progress < 0.25 then
				ToggleLoadingText.Text = "Processing Freeze Trade..."
			elseif progress < 0.5 then
				ToggleLoadingText.Text = "Almost there..."
			elseif progress < 0.75 then
				ToggleLoadingText.Text = "Just a moment..."
			else
				ToggleLoadingText.Text = "Finalizing..."
			end
		elseif loadingTime == 2 then
			-- For Auto Ready & Auto Accept (2 seconds)
			if progress < 0.33 then
				ToggleLoadingText.Text = "Almost there..."
			elseif progress < 0.66 then
				ToggleLoadingText.Text = "Just a moment..."
			else
				ToggleLoadingText.Text = "Finalizing..."
			end
		end

		-- Stop when done
		if progress >= 1 then
			connection:Disconnect()

			-- Execute the callback
			callback()

			-- Fade out
			local fadeOutInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

			tweenService:Create(ToggleLoadingFrame, fadeOutInfo, {BackgroundTransparency = 1}):Play()
			tweenService:Create(ToggleLoadingText, fadeOutInfo, {TextTransparency = 1}):Play()
			tweenService:Create(toggleBarBg, fadeOutInfo, {BackgroundTransparency = 1}):Play()

			wait(0.2)
			ToggleLoadingFrame.Visible = false

			isLoadingActive = false
		end
	end)
end

